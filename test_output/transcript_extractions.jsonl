exact", "extraction_index": 15, "group_index": 14, "description": null, "attributes": {"owner": "Jessica", "deadline": "null"}}, {"extraction_class": "action_item", "extraction_text": "I’ll get it from them by Friday.", "char_interval": {"start_pos": 917, "end_pos": 949}, "alignment_status": "match_exact", "extraction_index": 16, "group_index": 15, "description": null, "attributes": {"owner": "Sarah", "deadline": "Friday"}}, {"extraction_class": "speaker", "extraction_text": "David", "char_interval": {"start_pos": 986, "end_pos": 991}, "alignment_status": "match_exact", "extraction_index": 17, "group_index": 16, "description": null, "attributes": {"role": "team member", "mention_count": "1"}}, {"extraction_class": "topic", "extraction_text": "analytics for the landing page", "char_interval": {"start_pos": 1005, "end_pos": 1014}, "alignment_status": "match_lesser", "extraction_index": 18, "group_index": 17, "description": null, "attributes": {"importance": "medium"}}, {"extraction_class": "topic", "extraction_text": "conversion rate", "char_interval": {"start_pos": 1057, "end_pos": 1072}, "alignment_status": "match_exact", "extraction_index": 19, "group_index": 18, "description": null, "attributes": {"importance": "medium"}}, {"extraction_class": "topic", "extraction_text": "bounce rate on mobile", "char_interval": {"start_pos": 1102, "end_pos": 1123}, "alignment_status": "match_exact", "extraction_index": 20, "group_index": 19, "description": null, "attributes": {"importance": "high"}}, {"extraction_class": "topic", "extraction_text": "simplifying the mobile form", "char_interval": {"start_pos": 1176, "end_pos": 1203}, "alignment_status": "match_exact", "extraction_index": 21, "group_index": 20, "description": null, "attributes": {"importance": "high"}}, {"extraction_class": "action_item", "extraction_text": "Mike, can you work with the design team on a mobile-friendly form redesign?", "char_interval": {"start_pos": 1255, "end_pos": 1330}, "alignment_status": "match_exact", "extraction_index": 22, "group_index": 21, "description": null, "attributes": {"owner": "Mike", "deadline": "null"}}, {"extraction_class": "action_item", "extraction_text": "Let's reconvene on this same time next week to review the changes.", "char_interval": {"start_pos": 1383, "end_pos": 1449}, "alignment_status": "match_exact", "extraction_index": 23, "group_index": 22, "description": null, "attributes": {"owner": "all", "deadline": "next week"}}], "text": "Sarah: Hi everyone, thanks for hopping on. I want to keep this quick. We are looking at the Q2 marketing strategy, specifically for the new product launch. Mike, do you want to start us off with the campaign goals?\r\nMike: Sure. So, for Q2, our primary focus is driving sign-ups for the new app. We’re targeting a 15% increase in user acquisition compared to Q1. The main channels will be LinkedIn ads and the email nurture campaign.\r\nJessica: Quick question, Mike. Are we still featuring the testimonial video in the LinkedIn ads?\r\nMike: Yes, absolutely. It performed well in testing.\r\nSarah: That sounds good. What about content, Jessica? Are we on track for the blog posts?\r\nJessica: We are on track for the first three posts, but I’m running a bit behind on the whitepaper. I need to get the technical specs from the product team.\r\nSarah: I can help escalate that. Send me an email with exactly what you need, and I’ll get it from them by Friday.\r\nJessica: Perfect, will do.\r\nSarah: David, how are the analytics looking for the landing page?\r\nDavid: The conversion rate is solid, around 4%, but our bounce rate on mobile is higher than I’d like. I think we need to look at simplifying the mobile form.\r\nSarah: Okay, let’s add that to the action items. Mike, can you work with the design team on a mobile-friendly form redesign?\r\nMike: Yep, I’ll get that scheduled.\r\nSarah: Great. Let's reconvene on this same time next week to review the changes. Thanks, everyone.", "document_id": "doc_ff1f9788"}
